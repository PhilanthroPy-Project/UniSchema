# Copy to .env for local development. Never commit .env files.
PORT=3000

# SQLite database path (default: data/unischema.db). Use :memory: for ephemeral storage.
# DATABASE_URL=data/unischema.db

# Drift capture mode:
#   (default)     — dead-letter queue + local Vitest fixtures when filesystem is writable
#   queue-only    — dead-letter queue only (recommended for production / serverless)
#   disabled      — no drift capture
# DRIFT_CAPTURE=queue-only

# Webhook HMAC secrets — required in production (NODE_ENV=production)
# GiveCampus sends X-GiveCampus-Signature; Cvent sends X-Cvent-Signature
# CVENT_WEBHOOK_SECRET=
# GIVECAMPUS_WEBHOOK_SECRET=
# WEBHOOK_SIGNATURE_REQUIRED=true

# Egress push target: local | s3 | none
# EGRESS_TARGET=local
# EGRESS_LOCAL_DIR=data/egress

# Production S3 push (recommended for Airflow / analytics pipelines)
# EGRESS_TARGET=s3
# EGRESS_S3_BUCKET=your-data-lake-bucket
# EGRESS_S3_PREFIX=constituent-events
# AWS_REGION=us-east-1

# Frontend (frontend/.env) — API base URL for Sync to Engine
# VITE_API_BASE_URL=/api
