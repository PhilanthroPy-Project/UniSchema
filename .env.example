# Copy to .env for local development. Never commit .env files.
PORT=3000

# SQLite database path (default: data/unischema.db). Use :memory: for ephemeral storage.
# DATABASE_URL=data/unischema.db

# Drift capture mode:
#   (default)     — dead-letter queue only; CI workers generate Vitest fixtures
#   disabled      — no drift capture
# DRIFT_CAPTURE=disabled

# Drift agent runner (GitHub Action / Python script)
# DRIFT_AGENT_TOKEN=your-long-random-token

# Mapping sync API — required in production to prevent unauthorized canvas overwrites
# MAPPING_SYNC_TOKEN=your-long-random-token
# MAPPING_SYNC_REQUIRED=true

# Legacy pull-based egress auth — required in production (GET /egress/events, POST /egress/ack)
# EGRESS_PULL_TOKEN=your-long-random-token
# EGRESS_PULL_REQUIRED=true

# Webhook edge protection (application-level; also configure nginx/Cloudflare in production)
# Comma-separated IPv4 addresses or CIDR blocks (e.g. 203.0.113.10,198.51.100.0/24)
# WEBHOOK_IP_ALLOWLIST=
# WEBHOOK_RATE_LIMIT_MAX=120
# WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# Webhook HMAC secrets — required in production (NODE_ENV=production)
# GiveCampus sends X-GiveCampus-Signature; Cvent sends X-Cvent-Signature
# CVENT_WEBHOOK_SECRET=
# GIVECAMPUS_WEBHOOK_SECRET=
# WEBHOOK_SIGNATURE_REQUIRED=true

# Egress push target: local | s3 | none
# EGRESS_TARGET=local
# EGRESS_LOCAL_DIR=data/egress

# Production S3 push (recommended for Airflow / analytics pipelines)
# EGRESS_TARGET=s3
# EGRESS_S3_BUCKET=your-data-lake-bucket
# EGRESS_S3_PREFIX=constituent-events
# EGRESS_S3_BATCH_MAX_BYTES=5242880
# EGRESS_S3_FLUSH_INTERVAL_MS=120000
# AWS_REGION=us-east-1

# Airflow integration — webhook fires after each flushed NDJSON batch
# AIRFLOW_WEBHOOK_URL=https://airflow.example.com/api/v1/dags/unischema_ingest/dagRuns
# AIRFLOW_WEBHOOK_SECRET=shared-secret-for-airflow-rest-api

# LLM drift agent (agents/drift_runner)
# OPENAI_API_KEY=
# DRIFT_AGENT_MODEL=gpt-4o-mini

# Frontend (frontend/.env) — API base URL for Sync to Engine
# VITE_API_BASE_URL=/api
