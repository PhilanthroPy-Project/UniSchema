{
  "name": "unischema",
  "version": "0.4.1",
  "description": "Normalize advancement & nonprofit fundraising webhooks from 8 CRMs into one validated ConstituentEvent stream. TypeScript + Hono, self-hosted.",
  "type": "module",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PhilanthroPy-Project/UniSchema.git"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "npm run build -w unischema-frontend",
    "demo": "bash scripts/demo-webhook.sh",
    "demo:multi": "bash scripts/demo-webhook.sh --multi",
    "downstream-demo": "bash scripts/downstream-demo.sh",
    "benchmark": "bash scripts/load-benchmark.sh",
    "docker:up": "docker compose up --build",
    "docker:demo": "docker compose up --build -d && bash scripts/demo-webhook.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "drift-worker": "tsx scripts/drift-worker.ts",
    "test:security": "vitest run tests/unit/security.test.ts tests/integration/webhookSecurity.test.ts tests/integration/adminApiAuth.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:all": "npm test && npm run test -w unischema-frontend",
    "validate": "npm run typecheck && npm run test:security && npm run test:coverage && npm run typecheck -w unischema-frontend && npm run test -w unischema-frontend && npm run build"
  },
  "keywords": [
    "webhook",
    "university",
    "advancement",
    "nonprofit",
    "fundraising",
    "higher-education",
    "constituentevent",
    "typescript",
    "zod",
    "hono",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@hono/node-server": "^2.0.5",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "jose": "^6.2.3",
    "pg-boss": "^10.1.5",
    "postgres": "^3.4.9",
    "redis": "^4.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
