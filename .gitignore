# Dependencies & build artifacts
node_modules/
dist/
coverage/
*.tsbuildinfo

# Environment variables (never commit secrets)
.env
.env.*
!.env.example

# Credentials, keys, and local auth files
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
credentials.json
secrets.json
serviceAccountKey.json
**/service-account*.json
.npmrc

# SSH / TLS private material
id_rsa
id_ed25519
*.ppk

# OS & editor noise
.DS_Store
Thumbs.db
*.log
*.swp
.idea/
.vscode/

# AI / tooling exports (can embed full repo snapshots)
repomix-output.xml
**/repomix-output.xml

# Local-only test artifacts
data/
:memory:*
tests/__fixtures__/drift/*
!tests/__fixtures__/drift/.gitkeep
tests/autogenerated/*
!tests/autogenerated/.gitkeep
agents/output/
